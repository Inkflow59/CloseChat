{
  "name": "closechat",
  "version": "1.0.0",
  "description": "Application de chat en réseau local",
  "main": "src/main/electron.js",
  "author": "Inkflow59",
  "license": "ISC",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "cross-env NODE_ENV=development vite --config vite.config.ts --port 5173",
    "dev:electron": "cross-env NODE_ENV=development ELECTRON_RENDERER_URL=http://localhost:5173 electron .",
    "build:renderer": "vite build --config vite.config.ts",
    "build": "npm run build:renderer",
    "build:icons": "node scripts/generate-icons.js",
    "start": "npm run build:renderer && cross-env NODE_ENV=production electron .",
    "dist": "npm run build:renderer && electron-builder --win",
    "dist:dir": "npm run build:renderer && electron-builder --win --dir"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Inkflow59/CloseChat.git"
  },
  "bugs": {
    "url": "https://github.com/Inkflow59/CloseChat/issues"
  },
  "homepage": "https://github.com/Inkflow59/CloseChat#readme",
  "build": {
    "appId": "com.inkflow59.closechat",
    "productName": "CloseChat",
    "directories": {
      "output": "dist/installer"
    },
    "files": [
      "src/main/**/*",
      "src/renderer/src/**/*",
      "dist/renderer/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "resources", "to": ".", "filter": ["*.png", "*.ico"] }
    ],
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "zip",  "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CloseChat",
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico"
    },
    "linux": {
      "icon": "resources/icon.png",
      "target": ["AppImage", "zip"],
      "category": "Network"
    },
    "mac": {
      "icon": "resources/icon.png",
      "target": ["dmg", "zip"],
      "category": "public.app-category.social-networking"
    }
  },
  "keywords": [],
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/material": "^6.1.5",
    "jsonwebtoken": "^9.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
