    {
      "id": "c2xjuiugqIuHukfbdl7TR",
      "type": "text",
      "x": -2352.1758711494654,
      "y": -856.1719201183014,
      "width": 948.2550048828125,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dotted",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b34",
      "roundness": null,
      "seed": 249643106,
      "version": 131,
      "versionNonce": 1982141325,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775201013150,
      "link": null,
      "locked": false,
      "text": "CloseChat est une application de chat pensée pour les petits groupes et les vraies conversations. Pas de flux infini, pas\nd'algorithme : juste vous et les gens qui comptent.\n\nCréez ou rejoignez un salon, choisissez un pseudo, et commencez à discuter en temps réel. Les salons peuvent être publics\nou protégés par un mot de passe.\n\nNous croyons que les meilleures conversations se passent dans des espaces intimes, où l'on se connaît vraiment.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CloseChat est une application de chat pensée pour les petits groupes et les vraies conversations. Pas de flux infini, pas\nd'algorithme : juste vous et les gens qui comptent.\n\nCréez ou rejoignez un salon, choisissez un pseudo, et commencez à discuter en temps réel. Les salons peuvent être publics\nou protégés par un mot de passe.\n\nNous croyons que les meilleures conversations se passent dans des espaces intimes, où l'on se connaît vraiment.",
      "autoResize": true,
      "lineHeight": 1.25
    },
